{
  "Infrastructure": {
    "Persistence": {
      "Postgres": {
        "Host": "localhost",
        "Port": 5432,
        "Database": "lab5_tools",
        "Username": "postgres",
        "Password": "postgres",
        "SslMode": "Prefer",
        "Pooling": true
      }
    }
  },
  "ServiceUrl": {
    "BaseUrl": "http://localhost:5000"
  },
  "MessagePersistence": {
    "Publisher": {
      "Default": {
        "BatchSize": 100,
        "PollingDelay": "00:00:00.500"
      }
    },
    "Postgres": {
      "SchemaName": "message_persistence"
    }
  },
  "Presentation": {
    "Kafka": {
      "Host": "localhost:9092",
      "SecurityProtocol": "Plaintext",
      "Consumers": {
        "AccountCreation": {
          "IsDisabled": false,
          "Topic": "accounts_created",
          "Group": "lab5-tools.account-creation",
          "BufferSize": 1
        },
        "InvoiceCreation": {
          "IsDisabled": false,
          "Topic": "invoices_created",
          "Group": "lab5-tools.invoice-creation",
          "BufferSize": 1
        }
      },
      "Producers": {
        "ApprovalResult": {
          "Topic": "approvals_results",
          "Outbox": {
            "BatchSize": 100,
            "PollingDelay": "00:00:00.500"
          }
        }
      }
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "gRPC": {
        "Url": "http://*:8070",
        "Protocols": "Http2"
      }
    }
  },
  "Platform": {
    "ServiceName": "Lab5.Tools",
    "Observability": {
      "Tracing": {
        "IsEnabled": false
      },
      "Metrics": {
        "IsEnabled": false
      },
      "Sentry": {
        "IsEnabled": false,
        "Configuration": {
          "Dsn": "",
          "Debug": false,
          "TracesSampleRate": 1.0,
          "MinimumEventLevel": "Warning"
        }
      },
      "Logging": {
        "Serilog": {
          "MinimumLevel": {
            "Default": "Verbose",
            "Override": {
              "Microsoft.Hosting.Lifetime": "Information",
              "Microsoft.AspNetCore": "Warning",
              "Microsoft.Extensions.Http": "Information",
              "System.Net.Http.HttpClient": "Information",
              "Grpc.Net.Client": "Information",
              "Grpc.AspNetCore.Server": "Information",
              "Npgsql": "Information"
            }
          }
        }
      }
    }
  }
}
